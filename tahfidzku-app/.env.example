# ═══════════════════════════════════════════════════════
# TahfidzKu — Environment Variables
# ═══════════════════════════════════════════════════════
# Salin file ini menjadi .env lalu isi nilainya.
# cp .env.example .env
# ═══════════════════════════════════════════════════════

# ── Database (Neon.tech PostgreSQL) ──────────────────
# Dapatkan URL ini dari dashboard Neon.tech:
# https://console.neon.tech → Project → Connection Details → Connection string
DATABASE_URL=postgresql://username:password@ep-xxxxx.region.neon.tech/dbname?sslmode=require

# ── Autentikasi ──────────────────────────────────────
# Secret key untuk menandatangani session cookie.
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your-secret-key-min-32-characters-here

# ── Opsional ─────────────────────────────────────────
# Port dev server (default: 3000)
PORT=3000

# Environment mode
NODE_ENV=development

# ── Email Provider (Resend.com) ──────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
